<instance format="XCSP3" type="CSP">
    <variables>
        <array id="x" size="[3]"> 0..2 </array>
    </variables>
    <constraints>
        <mdd>
            <list> x[] </list>
            <transitions>
                (r,0,n1)(r,1,n2)(r,2,n3)
                (n1,2,n4)(n2,2,n4)(n3,0,n5)
                (n4,0,t)(n5,0,t)
            </transitions>
        </mdd>
    </constraints>
</instance>
