<instance format="XCSP3" type="COP">
    <variables>
        <var id="x"> 0..3 </var>
        <var id="y"> 0..3 </var>
    </variables>
    <constraints>
        <intension> le(add(x,y),5) </intension>
    </constraints>
    <objectives>
        <maximize type="sum">
            <list> x y </list>
            <coeffs> 1 1 </coeffs>
        </maximize>
    </objectives>
</instance>
