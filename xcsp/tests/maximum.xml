<instance format="XCSP3" type="CSP">
    <variables>
        <var id="x"> 0..3 </var>
        <var id="y"> 0..3 </var>
        <var id="z"> 0..3 </var>
    </variables>
    <constraints>
        <maximum>
            <list> x y z </list>
            <condition> (eq, 2) </condition>
        </maximum>
    </constraints>
</instance>
