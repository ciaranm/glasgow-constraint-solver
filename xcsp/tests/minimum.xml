<instance format="XCSP3" type="CSP">
    <variables>
        <var id="x"> 0..3 </var>
        <var id="y"> 0..3 </var>
        <var id="z"> 0..3 </var>
    </variables>
    <constraints>
        <minimum>
            <list> x y z </list>
            <condition> (eq, 1) </condition>
        </minimum>
    </constraints>
</instance>
