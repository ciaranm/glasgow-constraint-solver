<instance format="XCSP3" type="CSP">
    <variables>
        <var id="a"> 0..1 </var>
        <var id="b"> 0..1 </var>
        <var id="c"> 0..1 </var>
    </variables>
    <constraints>
        <nValues>
            <list> a b c </list>
            <condition> (eq, 1) </condition>
        </nValues>
    </constraints>
</instance>
