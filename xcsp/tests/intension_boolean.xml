<instance format="XCSP3" type="CSP">
    <variables>
        <var id="a"> 0..1 </var>
        <var id="b"> 0..1 </var>
        <var id="c"> 0..1 </var>
        <var id="d"> 0..1 </var>
    </variables>
    <constraints>
        <intension> and(imp(a,b),iff(b,not(c))) </intension>
        <intension> xor(a,c,d) </intension>
    </constraints>
</instance>
